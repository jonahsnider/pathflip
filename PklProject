amends "pkl:Project"

package {
  name = "pathflip"
  baseUri = "package://pkg.pkl-lang.org/github.com/jonahsnider/pathflip/pathflip"
  version = "4.1.0" // x-release-please-version
  packageZipUrl =
    "https://github.com/jonahsnider/pathflip/releases/download/pathflip@\(version)/pathflip@\(version).zip"
  description = "Configuration schema for pathflip, an FRC autonomous path mirroring tool."
  license = "Apache-2.0"
  authors {
    "Jonah Snider <jonah@jonahsnider.com>"
  }
  sourceCode = "https://github.com/jonahsnider/pathflip"
  sourceCodeUrlScheme =
    "https://github.com/jonahsnider/pathflip/blob/pathflip@\(version)%{path}#L%{line}-L%{endLine}"
  issueTracker = "https://github.com/jonahsnider/pathflip/issues"
  exclude {
    "dist/**"
    "node_modules/**"
    "test/**"
    ".github/**"
  }
}
